# Copy to .env.local for Vite. Only VITE_* vars are exposed to the client.

# Optional: team workspace via Vercel Blob (see README)
# VITE_SHARED_DSL=1

# Optional: Clerk sign-in before the workbench (see README + docs/HANDOFF_EPIC_USER_ORG_ENTERPRISE.md)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Set to 1 to skip the sign-in gate while developing (Clerk key can stay set)
# VITE_AUTH_DISABLED=1

# Server-only (Vercel env, not Vite): CLERK_SECRET_KEY — secures GET/PUT /api/shared-dsl
# Optional: CAPACITY_CLERK_AUTHORIZED_PARTIES=https://your-app.vercel.app,http://localhost:5173
# Optional: CAPACITY_DISABLE_LEGACY_SHARED_DSL_WRITE=1 — with CLERK_SECRET_KEY, PUT accepts only Clerk JWT (not CAPACITY_SHARED_DSL_SECRET)
