# Copy to .env.local for Vite. With `envPrefix` in vite.config, both `VITE_*` and `NEXT_PUBLIC_*`
# keys from this file are exposed to the client when referenced in app source.

# Optional: team workspace via Vercel Blob (see README)
# VITE_SHARED_DSL=1

# ---------------------------------------------------------------------------
# Clerk (Vercel User & Authentication / Marketplace — canonical)
# ---------------------------------------------------------------------------
# Client (safe to expose): use the names Vercel sets on the project
# NEXT_PUBLIC_CLERK_AUTHENTICATION_CLERK_PUBLISHABLE_KEY=pk_test_...
#
# Legacy alias (optional — same pk value if you already use Vite-only naming):
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
#
# Server-only (never VITE_*): JWT verification for /api/* — Vercel sets:
# CLERK_AUTHENTICATION_CLERK_SECRET_KEY=sk_test_...
#
# Legacy alias (optional):
# CLERK_SECRET_KEY=sk_test_...
#
# Production: use pk_live_… / sk_live_… from the same Clerk application.

# Optional: restrict who can use the app and APIs (comma-separated, case-insensitive). Must match on client + Vercel server.
# Add to Clerk → Sessions → Customize session token JSON: "email": "{{user.primary_email_address}}"
# VITE_ALLOWED_USER_EMAILS=you@example.com,other@example.com
# CAPACITY_ALLOWED_USER_EMAILS=you@example.com,other@example.com

# Set to 1 to skip the sign-in gate while developing (Clerk key can stay set)
# VITE_AUTH_DISABLED=1

# Optional: CAPACITY_CLERK_AUTHORIZED_PARTIES=https://your-app.vercel.app,http://localhost:5173,http://localhost:3000
# Optional: CAPACITY_DISABLE_LEGACY_SHARED_DSL_WRITE=1 — with Clerk secret set, PUT accepts only Clerk JWT (not CAPACITY_SHARED_DSL_SECRET)
# Optional: CAPACITY_CLERK_DSL_WRITE_ROLES=admin,member,editor — JWT org role (session o.rol / org_role) must be in this list to PUT; unset = any signed-in user
# Optional (client, match server list): VITE_CLERK_DSL_WRITE_ROLES=admin,member,editor — disables save UI when role not allowed
# Optional: CAPACITY_ORG_ADMIN_ROLES=admin — org roles (JWT o.rol) that count as workspace admin alongside session claims
# Optional (client, match server): VITE_CAPACITY_ORG_ADMIN_ROLES=admin
#
# Segment / editor ACL (Clerk → Sessions → Customize session token). Omit all three for legacy behaviour (full workspace).
#   cap_admin — true = all markets + edit
#   cap_segs — e.g. "LIOM" or "LIOM,IOM" (codes from public/data/segments.json)
#   cap_ed — true = may edit YAML for allowed segment markets; false = viewer (read-only UI + GET filtered; PUT rejected)
#
# ---------------------------------------------------------------------------
# Canonical workspace: Supabase Postgres + Redis cache (server-only; see docs/SUPABASE_REDIS_WORKSPACE.md)
# ---------------------------------------------------------------------------
# Serverless reads these first; if you only set the Vite-prefixed URL for the client, duplicate it here or the API will not see it:
# SUPABASE_URL=https://xxxx.supabase.co
# (alias) VITE_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # never expose to Vite / browser
# (alias) SUPABASE_SECRET_KEY=eyJ...   # some Vercel integrations use this name
# Optional: direct Postgres for pg/Drizzle (pooler connection string from Supabase dashboard)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Redis cache for merged bundle / hot reads (Upstash example)
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# Optional: TTL seconds for bundle keys (app default may be 120–300)
# CAPACITY_WORKSPACE_CACHE_TTL_SECONDS=180
